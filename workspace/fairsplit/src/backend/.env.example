# FairSplit Backend — Environment Variables
# Copy this file to .env for local development (never commit .env to git).
#
# Generate a secure SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string using the asyncpg driver.
# For local docker-compose: the values below match the docker-compose.yml defaults.
DATABASE_URL=postgresql+asyncpg://fairsplit:fairsplit_dev@localhost:5432/fairsplit

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT signing key. Must be at least 32 random characters.
# CHANGE THIS IN PRODUCTION — the default is only safe for local development.
SECRET_KEY=dev_secret_key_minimum_32_characters_change_in_prod

# JWT algorithm — HS256 is the correct choice for symmetric (single-server) signing.
JWT_ALGORITHM=HS256

# JWT expiry in days — 30 days is the default (rolling, reset on each valid request).
JWT_EXPIRY_DAYS=30

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local development: only localhost:3000 is needed.
# For production: set this to your actual frontend domain(s).
CORS_ORIGINS=http://localhost:3000

# ─── Application ──────────────────────────────────────────────────────────────
# Environment name. Controls security headers (HSTS) and cookie secure flag.
# Values: development | production
ENVIRONMENT=development

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level. Structured JSON is always emitted; this controls verbosity.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── Application URL ──────────────────────────────────────────────────────────
# Base URL of the frontend application, used in settle-up clipboard text.
APP_BASE_URL=http://localhost:3000
