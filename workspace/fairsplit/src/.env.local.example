# FairSplit — local development environment variables
#
# Copy this file to .env.local and fill in any values you need to override.
# docker-compose.yml sets all of these automatically for the Docker stack.
# This file is only needed when running services outside Docker (e.g. pytest locally).
#
# NEVER commit .env.local to version control.

# ── Backend ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver)
# Points to the Docker Compose db service when running locally.
DATABASE_URL=postgresql+asyncpg://fairsplit:fairsplit_dev@localhost:5432/fairsplit

# JWT signing secret — minimum 32 characters.
# Generate a real one with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in staging/production — must be set via fly secrets set SECRET_KEY=...
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Application environment: development | test | production
ENVIRONMENT=development

# Structured log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Base URL for clipboard text in settle-up (used in invite links)
APP_BASE_URL=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────────────

# Backend API URL — consumed by Next.js at build time and runtime
NEXT_PUBLIC_API_URL=http://localhost:8000

# Show the dev panel on the login page (click-to-fill seeded accounts).
# Set via Dockerfile ARG in docker-compose — NEVER use NODE_ENV for this.
# Must be the string "true" (not a boolean) to match the === "true" check.
NEXT_PUBLIC_SHOW_DEV_PANEL=true

# ── Secrets required for staging/production (not used locally) ────────────

# Fly.io API token — set in GitHub Secrets as FLY_API_TOKEN
# FLY_API_TOKEN=

# Vercel deploy token — set in GitHub Secrets as VERCEL_TOKEN
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# Production backend URL (used by smoke_test.py and CD workflow)
# PRODUCTION_API_URL=https://fairsplit-backend.fly.dev
# PRODUCTION_FRONTEND_URL=https://fairsplit.vercel.app

# VPS deployment (alternative to Fly.io — set DEPLOY_TARGET=vps in GitHub vars)
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY=   (private key — set as GitHub Secret)
